# ============================================================
#  StudyBuddy — Environment Variables
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local to version control.
# ============================================================

# ── Anthropic API (REQUIRED) ─────────────────────────────────
# Server-only. Never prefix with NEXT_PUBLIC_.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase (REQUIRED) ──────────────────────────────────────
# These are intentionally public-safe (anon key only).
# Get values from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Resend email (OPTIONAL) ──────────────────────────────────
# Server-only. Never prefix with NEXT_PUBLIC_.
# Required only for parent homework alert emails.
# Without this key, alerts are silently skipped (app still works).
# Get your key at: https://resend.com
# The sending domain (studybuddy.cabreraai.com) must be verified in Resend.
RESEND_API_KEY=your_resend_api_key_here
